#%RAML 1.0 Library
usage: Security schemes for client credential enforcement

securitySchemes:
  clientEnforcement:
    type: x-client-id-enforcement
    description: Secures the API requiring a Client ID and Secret provided by Anypoint API Manager.
    describedBy:
      headers:
        client_id:
          type: string
          required: true
        client_secret:
          type: string
          required: true
      responses:
        401:
          description: Unauthorized or invalid client application credentials.
        403:
          description: Client not authorized to access this API.

